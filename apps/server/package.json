{
  "name": "@tibia-game/server",
  "version": "1.0.0",
  "description": "Tibia-like game server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && xcopy src\\game\\*.json dist\\apps\\server\\src\\game\\ /E /I /Y",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.7",
    "@types/pg": "^8.10.7",
    "@types/cors": "^2.8.15",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
